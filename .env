# Copy as .env file and fill your values below


# OpenAI-compatible backend (OpenRouter or local Ollama/LM Studio)
OPENAI_BASE_URL=#Your OpenRouter URL or local model URL, e.g. http://localhost:11434/v1
OPENAI_API_KEY=#Your OpenAI API key or OpenRouter API key
OPENROUTER_API_KEY=#Your OpenRouter API key (if using OpenRouter)
OPENROUTER_SITE_URL=#Your OpenRouter site URL
OPENROUTER_APP_NAME=machine-learning-engineering

# Model ID used in agents (OpenRouter examples or local model)
ROOT_AGENT_MODEL=gpt-oss-120b-llmlb